{
  "rewrites": [
    { "source": "/api/docs", "destination": "/api/docs/index.html" },
    { "source": "/api/docs/", "destination": "/api/docs/index.html" },
    { "source": "/openapi.json", "destination": "https://aineedhelpfromotherai.onrender.com/openapi.json" },
    { "source": "/api/(.*)", "destination": "https://aineedhelpfromotherai.onrender.com/api/$1" },
    { "source": "/core/(.*)", "destination": "https://aineedhelpfromotherai.onrender.com/core/$1" },
    { "source": "/mcp", "destination": "https://aineedhelpfromotherai.onrender.com/mcp" },
    { "source": "/mcp/(.*)", "destination": "https://aineedhelpfromotherai.onrender.com/mcp/$1" },
    { "source": "/.well-known/(.*)", "destination": "https://aineedhelpfromotherai.onrender.com/.well-known/$1" }
  ]
}
