---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map(c => ({
    params: { slug: c.data.id.toLowerCase() },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const md = entry.data;
---

<BaseLayout
  title={`${md.id} — ${md.title}`}
  description={md.rootCause.substring(0, 160)}
  canonical={`https://aineedhelpfromotherai.com/cases/${md.id.toLowerCase()}/`}
  ogType="article"
  keywords={md.tags.join(', ')}
  schema={{
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": `${md.id} — ${md.title}`,
    "description": md.rootCause.substring(0, 200),
    "author": { "@type": "Organization", "name": "AI Failure Observatory" },
    "keywords": md.tags.join(', '),
  }}
>
  <main class="page">
    <div class="wrap">
      <section class="hero">
        <div>
          <div class="eyebrow">{md.agent} · {md.framework} · {md.environment}</div>
          <h1>{md.id} — {md.title}</h1>
          <div class="tags">
            {md.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <div class="stats">
            <div class="stat"><strong>{md.timeWastedMinutes}m</strong><span>Time wasted</span></div>
            <div class="stat"><strong>{md.failureType}</strong><span>Failure type</span></div>
            <div class="stat"><strong>{md.dynamics.join(', ')}</strong><span>Pattern</span></div>
          </div>
        </div>
        <aside class="side">
          <div style="background:var(--warn);border:1px solid #f0d6c0;border-radius:8px;padding:18px;">
            <b style="font-size:15px;">Known trap</b>
            <p style="margin:8px 0 0;font-size:14px;line-height:1.74;color:var(--muted);">{md.wrongTurn.substring(0, 200)}</p>
          </div>
        </aside>
      </section>

      <section class="section">
        <div class="content">
          <Content />
        </div>
      </section>

      <section class="section">
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="/cases/" class="btn secondary">← All cases</a>
          <a href="/#search-memory" class="btn">Search memory</a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .wrap { width: min(1120px, calc(100% - 56px)); margin: 0 auto; }
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, .78fr);
    gap: 68px;
    align-items: start;
    padding: 58px 0 38px;
  }
  .eyebrow { color: var(--accent); font-size: 12px; font-weight: 800; text-transform: uppercase; margin-bottom: 18px; }
  h1 { margin: 0; font-size: clamp(28px, 3vw, 40px); line-height: 1.15; font-weight: 680; }
  .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
  .tag { border: 1px solid var(--line); background: var(--surface-2); border-radius: 999px; padding: 4px 10px; font-size: 11.5px; color: var(--muted); }
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; background: var(--surface); margin-top: 28px; }
  .stat { padding: 18px; } .stat + .stat { border-left: 1px solid var(--line); }
  .stat strong { display: block; font-size: 22px; line-height: 1.08; margin-bottom: 6px; }
  .stat span { color: var(--muted); font-size: 12px; }
  .section { padding: 48px 0; border-top: 1px solid var(--line); }
  .content { max-width: 760px; font-size: 16px; line-height: 1.84; color: var(--muted); }
  .content :global(h2) { margin: 32px 0 14px; font-size: 24px; font-weight: 680; color: var(--ink); }
  .content :global(ul) { margin: 12px 0; padding-left: 22px; }
  .content :global(li + li) { margin-top: 6px; }
  .content :global(p) { margin: 12px 0; }
  .btn { display: inline-flex; align-items: center; justify-content: center; min-height: 52px; border: 1px solid var(--ink); background: var(--ink); color: #fff; border-radius: 8px; padding: 0 18px; font-size: 14px; font-weight: 760; cursor: pointer; text-decoration: none; }
  .btn.secondary { background: #fff; color: var(--ink); border-color: var(--line-strong); }
  .btn:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(20,24,23,.08); }

  @media (max-width: 900px) { .hero { grid-template-columns: 1fr; gap: 32px; } }
  @media (max-width: 640px) { .stats { grid-template-columns: 1fr; } .stat + .stat { border-left: 0; border-top: 1px solid var(--line); } }
</style>