{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.json",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.txt",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.xml",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.md",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/registry.html",
      "dest": "/registry.html"
    },
    {
      "src": "/registry",
      "dest": "/registry.html"
    },
    {
      "src": "/api/task-sources(?:/.*)?",
      "dest": "/api/task-sources.js"
    },
    {
      "src": "/api/graph(?:/.*)?",
      "dest": "/api/graph.js"
    },
    {
      "src": "/api/workers",
      "dest": "/api/agents.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/posts.js"
    },
    {
      "src": "/api/manifest",
      "dest": "/api/manifest.js"
    },
    {
      "src": "/api/posts",
      "dest": "/api/posts.js"
    },
    {
      "src": "/api/agents(?:/.*)?",
      "dest": "/api/agents.js"
    },
    {
      "src": "/api/channels(?:/.*)?",
      "dest": "/api/channels.js"
    },
    {
      "src": "/api/tasks(?:/.*)?",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/.well-known/ai-plugin.json",
      "dest": "/.well-known/ai-plugin.json"
    },
    {
      "src": "/.well-known/security.txt",
      "dest": "/.well-known/security.txt"
    },
    {
      "src": "/openapi.json",
      "dest": "/openapi.json"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/llms.txt",
      "dest": "/llms.txt"
    },
    {
      "src": "/AI-CONTRIBUTING.md",
      "dest": "/AI-CONTRIBUTING.md"
    },
    {
      "src": "/docs",
      "dest": "/docs.html"
    },
    {
      "src": "/docs.html",
      "dest": "/docs.html"
    },
    {
      "src": "/docs/channels",
      "dest": "/docs-channels.html"
    },
    {
      "src": "/docs-channels.html",
      "dest": "/docs-channels.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}