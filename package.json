{
  "name": "aineedhelpfromotherai",
  "version": "1.0.0",
  "private": true,
  "description": "Failure intelligence layer for AI coding agents. MCP server + REST API for reusable reasoning, failure checks, and shared debugging memory.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "debugging",
    "failure-analysis",
    "memory-layer",
    "llm-tools",
    "agent-memory",
    "error-patterns",
    "coding-agents"
  ],
  "homepage": "https://aineedhelpfromotherai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/chenyuan35/aineedhelpfromotherai.git"
  },
  "bugs": {
    "url": "https://github.com/chenyuan35/aineedhelpfromotherai/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chenyuan35"
  },
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "bash test-api.sh",
    "verify": "node scripts/run-verify.js",
    "verify:win": "pwsh scripts/ci-verify.ps1",
    "eval": "node scripts/ci-eval.js && node scripts/generate-eval-report.js",
    "eval:baseline": "node scripts/ci-eval.js --baseline",
    "eval:passk": "node scripts/ci-eval.js --passk=5",
    "eval:rss": "node scripts/ci-eval.js --rss",
    "test:trust": "node scripts/test-trust-tiers.js",
    "pipeline": "node scripts/reality-pipeline.js",
    "pipeline:harvest": "node scripts/reality-pipeline.js --harvest-only",
    "pipeline:convert": "node scripts/reality-pipeline.js --convert-only",
    "pipeline:adversarial": "node scripts/reality-pipeline.js --adversarial-only",
    "pipeline:full": "node scripts/reality-pipeline.js",
    "pipeline:cycle": "node scripts/run-lib.js pipeline:cycle",
    "pipeline:report": "node scripts/generate-mining-report.js",
    "pipeline:verify": "node scripts/run-lib.js pipeline:verify",
    "pipeline:validate": "node scripts/run-lib.js pipeline:validate",
    "pipeline:feedback": "node scripts/run-lib.js pipeline:feedback",
    "pipeline:remediate": "node scripts/run-lib.js pipeline:remediate",
    "pipeline:llm-eval": "node scripts/run-lib.js pipeline:llm-eval",
    "patterns": "node scripts/run-lib.js patterns",
    "solve": "node scripts/run-lib.js solve",
    "seeds:inject": "node scripts/run-lib.js seeds:inject",
    "migrate:neon": "node scripts/migrate-to-neon.js",
    "migrate:neon:dry": "node scripts/migrate-to-neon.js --dry-run",
    "prepush": "npm run verify"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "cors": "2.8.6",
    "dotenv": "^17.4.2",
    "express": "5.2.1",
    "libsodium-wrappers": "^0.8.4",
    "pg": "^8.13.0",
    "ssh2": "^1.17.0",
    "winston": "^3.9.0",
    "zod": "4.4.3"
  }
}
