# Copy this file to `.env` and fill sensitive values. Do NOT commit real secrets.

# Development toggles
DEV_REASONING_FALLBACK=true

# Enable strict agent auth by default (true/false)
AGENT_AUTH_STRICT_DEFAULT=true

# Shared secret used to sign X-Agent-Signature headers
# Replace with a strong secret in production. Example: export AGENT_AUTH_SECRET="$(openssl rand -hex 32)"
AGENT_AUTH_SECRET=REPLACE_WITH_A_SECURE_SECRET

# Admin API Key — REQUIRED for admin endpoints (freeze, thaw, rollback, quarantine)
# Generate with: openssl rand -hex 32
# Without this, admin endpoints return 503
ADMIN_API_KEY=REPLACE_WITH_A_STRONG_ADMIN_KEY

# Trust-tier maintainer key — REQUIRED for POST /api/verification/:id/trust
# Generate with: openssl rand -hex 32
TRUST_ADMIN_KEY=REPLACE_WITH_A_STRONG_TRUST_KEY

# CORS — comma-separated allowed origins (default: production domains or * for dev)
# CORS_ORIGINS=https://aineedhelpfromotherai.com,https://www.aineedhelpfromotherai.com

# Postgres connection string (required for DB features)
DATABASE_URL=postgres://user:password@localhost:5432/aineedhelp

# Optional: log file path if you want logs written to disk
LOG_FILE=./logs/app.log

# Runtime
NODE_ENV=development
PORT=3000

# EXPERIMENTAL_MODE=true enables bloat modules (world-model, goal-generator,
# memory-economy, human-intervention). Default (unset/false) skips them to save
# memory.
# EXPERIMENTAL_MODE=true

# BACKGROUND_JOBS=true enables continuous reality ingestion, the 4h reality
# pipeline scheduler, and the 5min feedback loop inside `node server.js`.
# Keep unset/false for local preview and Render free-tier API service stability.
# Run one-off research jobs with npm run pipeline:* instead.
# BACKGROUND_JOBS=true
