# Copy this file to `.env` and fill sensitive values. Do NOT commit real secrets.

# Development toggles
DEV_REASONING_FALLBACK=true

# Enable strict agent auth by default (true/false)
AGENT_AUTH_STRICT_DEFAULT=true

# Shared secret used to sign X-Agent-Signature headers
# Replace with a strong secret in production. Example: export AGENT_AUTH_SECRET="$(openssl rand -hex 32)"
AGENT_AUTH_SECRET=REPLACE_WITH_A_SECURE_SECRET
# Environment example for aineedhelpfromotherai
# Copy to .env and fill values for your deployment

# Postgres connection string (required for DB features)
DATABASE_URL=postgres://user:password@localhost:5432/aineedhelp

# Weak agent auth shared secret (rotate in production)
AGENT_AUTH_SECRET=change_this_secret_in_production

# Optional: log file path if you want logs written to disk
LOG_FILE=./logs/app.log

# Runtime
NODE_ENV=development
PORT=3000
